# ── 경락이(LSB) 환경변수 ── (.env 로 복사 / Render는 대시보드 Environment에 입력)

# Slack (필수) — HTTP/Events API 모드
SLACK_BOT_TOKEN=xoxb-...          # Bot User OAuth Token
SLACK_SIGNING_SECRET=...          # Basic Information → Signing Secret
# (선택) 과거 메시지 검색용 User Token (search:read). 없으면 최근 history 스캔 폴백.
SLACK_USER_TOKEN=

# 봇이 검색·답변을 허용할 채널 (쉼표 구분). 권한모델 B = 화이트리스트.
LSB_ALLOWED_CHANNELS=C028C2HTZNZ
# (선택) 봇 사용 허용 사용자 ID. 비우면 전체 허용.
LSB_ALLOWED_USERS=

# Anthropic (필수)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
LSB_MAX_LOOPS=8

# Notion (선택) — 보고문서가 Notion에 있을 때
NOTION_TOKEN=

# Google Drive (선택) — 보고문서가 Drive에 있을 때 (서비스 계정 JSON 전체를 한 줄로)
GOOGLE_SERVICE_ACCOUNT_JSON=
LSB_DRIVE_FOLDER_IDS=

# 공통
LSB_MAX_HITS=6
LSB_PERMISSION_TAG=ga-channel-whitelist

# 서버 (로컬은 비워두면 3000. Render는 자동 주입하므로 설정 불필요)
PORT=3000
